<!-- Cookie consent (minimal). Sites GA4 only after explicit accept. -->
<div id="cc-banner" class="cc-banner" role="region" aria-label="Cookie notice" hidden>
  <p>This site uses Google Analytics to understand how visitors find and use the research. No personal information is collected. <a href="./about.html#contact">Questions →</a></p>
  <div class="cc-banner__btns">
    <button type="button" class="btn btn--ghost" data-cc-deny>Decline</button>
    <button type="button" class="btn btn--primary" data-cc-accept>Accept</button>
  </div>
</div>
<script>
  (function () {
    var KEY = 'cc-v1';
    var pref = null;
    try { pref = localStorage.getItem(KEY); } catch (e) {}
    var banner = document.getElementById('cc-banner');
    function apply(accepted) {
      try { localStorage.setItem(KEY, accepted ? 'accept' : 'deny'); } catch (e) {}
      if (banner) banner.hidden = true;
      if (accepted && window.gtag) {
        window.gtag('consent', 'update', {
          analytics_storage: 'granted'
        });
      }
    }
    if (pref === 'accept') {
      if (window.gtag) window.gtag('consent', 'update', { analytics_storage: 'granted' });
    } else if (pref === 'deny') {
      /* stays denied */
    } else if (banner) {
      banner.hidden = false;
    }
    if (banner) {
      banner.querySelector('[data-cc-accept]').addEventListener('click', function(){ apply(true); });
      banner.querySelector('[data-cc-deny]').addEventListener('click', function(){ apply(false); });
    }
  })();
</script>

